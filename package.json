  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@biomejs/biome": "2.5.5",
    "@types/react": "~19.1.1",
    "babel-preset-expo": "~55.0.8",
    "expo": "^57.0.7",
    "expo-module-scripts": "^56.0.3",
    "react-native": "0.82.1",
    "typescript": "^5.9.2"
  },
  "peerDependencies": {
    "expo": "*",
    "react": "*",
    "react-native": ">=0.75.5"
  }
