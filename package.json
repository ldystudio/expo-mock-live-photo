{
  "name": "expo-mock-live-photo",
  "version": "0.1.0",
  "description": "Simulate Live Photo playback from an image and a video",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "packageManager": "bun@1.3.14",
  "files": [
    "android/build.gradle",
    "android/src/main",
    "build",
    "ios/ExpoMockLivePhoto.podspec",
    "ios/ExpoMockLivePhotoModule.swift",
    "ios/ExpoMockLivePhotoView.swift",
    "ios/PlaybackState.swift",
    "expo-module.config.json"
  ],
  "scripts": {
    "build": "rm -rf build && tsc",
    "check": "biome check .",
    "format": "biome format --write .",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepare": "node internal/module_scripts/prepare.js",
    "open:ios": "node internal/module_scripts/open-ios.js",
    "open:android": "node internal/module_scripts/open-android.js"
  },
  "keywords": [
    "react-native",
    "expo",
    "expo-mock-live-photo",
    "ExpoMockLivePhoto"
  ],
  "author": "Liudy <1187551003@qq.com> (https://github.com/ldystudio)",
  "license": "MIT",
  "homepage": "https://github.com/ldystudio/expo-mock-live-photo",
  "dependencies": {},
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@biomejs/biome": "2.5.5",
    "@types/bun": "^1.3.14",
    "@types/react": "~18.2.79",
    "babel-preset-expo": "~11.0.15",
    "expo": "~51.0.39",
    "expo-module-scripts": "~3.5.4",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "typescript": "~5.3.3"
  },
  "peerDependencies": {
    "expo": "*",
    "react": "*",
    "react-native": ">=0.74.5"
  }
}
